# ─────────────────────────────────────────────────────────────────────────────
# Grenoucerie Agents — Variables de entorno
# Copia este archivo a .env y rellena los valores
# ─────────────────────────────────────────────────────────────────────────────

# OpenRouter (LLM principal)
OPENROUTER_API_KEY=TU_CLAVE_OPENROUTER_AQUI
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL_NAME=deepseek/deepseek-chat

# Base de datos PostgreSQL (misma que usa el CRM)
# Supabase → Settings → Database → Connection string → Transaction pooler
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-west-3.pooler.supabase.com:6543/postgres

# (Opcional) Migración futura a Anthropic Claude
# OPENAI_API_BASE=https://api.anthropic.com/v1
# OPENAI_MODEL_NAME=claude-sonnet-4-6
# ANTHROPIC_API_KEY=TU_CLAVE_ANTHROPIC_AQUI

# URL del CRM (para llamadas internas)
CRM_URL=http://localhost:3000
