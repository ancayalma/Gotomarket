{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@/ui/*": [
        "./components/ui/*"
      ]
    }
  },
  "ts-node": {
    "compilerOptions": {
      "module": "commonjs"
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "check-account-candidates.ts",
    "check-distribution.ts",
    "check-lead-distribution.ts",
    "check-orphans.ts",
    "check-recent-invoices.ts",
    "cross-db-check.ts",
    "debug_prisma.ts",
    "debug-counts.ts",
    "get_ref_data.ts",
    "fix_xoinpay.ts",
    "find-missing-leads.ts",
    "find-big-tables.ts",
    "list-collections.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}