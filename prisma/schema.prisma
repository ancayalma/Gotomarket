// Phase 3: Recurring Payments & Subscriptions
model crm_Subscriptions {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @default(0) @map("__v")
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  tenant_id String @unique @db.ObjectId
  team      Team   @relation(fields: [tenant_id], references: [id])

  account_id String?       @db.ObjectId
  account    crm_Accounts? @relation(fields: [account_id], references: [id])

  // Payment Provider
  payment_provider String @default("SURGE") // "STRIPE" or "SURGE"

  // Stripe Identity
  stripe_customer_id     String? // Stripe Customer ID (cus_xxx)
  stripe_subscription_id String? // Stripe Subscription ID (sub_xxx)

  // Surge Identity
  surge_vault_token String? // The token provided by Surge after card entry
  customer_email    String?
  customer_wallet   String? // Optional 0x wallet for Hybrid Fallback / Direct Crypto
  discount_applied  Boolean @default(false) // 5% Discount for BasaltSurge manual payment

  // Billing Config
  plan_name   String
  amount      Float
  currency    String @default("USD")
  interval    String @default("monthly") // monthly, yearly
  billing_day Int    @default(14) // e.g. 14th of the month

  next_billing_date DateTime @db.Date
  status            String   @default("ACTIVE") // ACTIVE, PAUSED, CANCELLED, OVERDUE, SUSPENDED

  // Metadata for receipts
  last_charge_date    DateTime? @db.Date
  last_charge_status  String?
  last_transaction_id String?
  metadata            Json?

  // Billing invoices for this subscription
  invoices crm_BillingInvoice[]

  // Synthesis Layer (AI Memory)
  knowledgeSignals KnowledgeSignal[]

  @@index([next_billing_date])
}

// Per-cycle billing invoices (subscription receipts)
model crm_BillingInvoice {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  v         Int      @default(0) @map("__v")
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  tenant_id String @db.ObjectId
  team      Team   @relation(fields: [tenant_id], references: [id])

  subscription_id String?            @db.ObjectId
  subscription    crm_Subscriptions? @relation(fields: [subscription_id], references: [id])

  // Invoice details
  invoice_number String   @unique
  type           String   @default("SUBSCRIPTION") // SUBSCRIPTION, AI_USAGE, ECHO_CREDITS, ONE_TIME
  description    String?
  period_start   DateTime @db.Date
  period_end     DateTime @db.Date

  // Amounts
  subtotal Float
  discount Float @default(0)
  tax      Float @default(0)
  total    Float

  // Payment info
  payment_method String? // "CARD", "CRYPTO", "SYSTEM_CREDIT"
  payment_status String    @default("PENDING") // PENDING, PAID, FAILED, REFUNDED, WAIVED
  transaction_id String?
  paid_at        DateTime? @db.Date

  // Line items stored as JSON array
  // [{ description: string, quantity: number, unit_price: number, total: number }]
  line_items Json?

  // PDF generation
  pdf_url String?

  @@index([tenant_id])
  @@index([subscription_id])
  @@index([type])
  @@index([payment_status])
  @@index([period_start])
}

// Monthly AI consumption tracking (platform AI: text gen, email, Varuni — NOT BasaltECHO)
model crm_AiUsageLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @db.Date

  tenant_id String @db.ObjectId
  team      Team   @relation(fields: [tenant_id], references: [id])

  user_id String? @db.ObjectId
  user    Users?  @relation(name: "AiUsageUser", fields: [user_id], references: [id], onDelete: SetNull)

  // Usage details
  service    String // "text_generation", "email_ai", "varuni", "enrichment", "lead_scoring", etc.
  model_used String? // "gpt-4o", "claude-3.5-sonnet", etc.
  tokens_in  Int     @default(0)
  tokens_out Int     @default(0)
  cost       Float   @default(0) // Calculated cost in USD

  // Context
  description String? // e.g., "Email compose for lead John Doe"
  metadata    Json?

  @@index([tenant_id])
  @@index([user_id])
  @@index([service])
  @@index([createdAt])
}

// -----------------------------------------------------------------------------
// SOC2 / GDPR Data Retention Policies
// -----------------------------------------------------------------------------
model DataRetentionPolicy {
  id             String  @id @default(auto()) @map("_id") @db.ObjectId
  model_name     String  @unique // e.g., "SystemActivity"
  retention_days Int
  action         String // "DELETE" | "ANONYMIZE"
  enabled        Boolean @default(true)
}

// SOC2: Added to enforce instant global session invalidation across all devices
// on security events (password reset, role change, MFA addition/removal, deactivation).

// -----------------------------------------------------------------------------
// Synthesis Layer (AI Memory)
// -----------------------------------------------------------------------------

model ContextNode {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  accountId String? @db.ObjectId
  leadId    String? @db.ObjectId

  summary         String?
  lifecycleStatus String?
  sentimentScore  Float?
  intentLevel     String?

  account crm_Accounts? @relation(fields: [accountId], references: [id])
  lead    crm_Leads?    @relation(fields: [leadId], references: [id])

  knowledgeSignals KnowledgeSignal[]
  embeddings       VectorEmbedding[]

  @@index([accountId])
  @@index([leadId])
}

model KnowledgeSignal {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @db.Date

  contextNodeId String?      @db.ObjectId
  contextNode   ContextNode? @relation(fields: [contextNodeId], references: [id])

  type       String
  content    String
  confidence Float?

  sourceType String
  sourceUrl  String?

  accountId      String? @db.ObjectId
  leadId         String? @db.ObjectId
  outreachItemId String? @db.ObjectId
  taskId         String? @db.ObjectId
  invoiceId      String? @db.ObjectId
  subscriptionId String? @db.ObjectId

  account      crm_Accounts?       @relation(fields: [accountId], references: [id])
  lead         crm_Leads?          @relation(fields: [leadId], references: [id])
  outreachItem crm_Outreach_Items? @relation(fields: [outreachItemId], references: [id])
  task         Tasks?              @relation(fields: [taskId], references: [id])
  invoice      Invoices?           @relation(fields: [invoiceId], references: [id])
  subscription crm_Subscriptions?  @relation(fields: [subscriptionId], references: [id])

  embeddings VectorEmbedding[]

  @@index([contextNodeId])
  @@index([accountId])
  @@index([leadId])
}

model VectorEmbedding {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now()) @db.Date

  embedding Float[]

  text String

  contextNodeId     String? @db.ObjectId
  knowledgeSignalId String? @db.ObjectId

  contextNode     ContextNode?     @relation(fields: [contextNodeId], references: [id])
  knowledgeSignal KnowledgeSignal? @relation(fields: [knowledgeSignalId], references: [id])

  @@index([contextNodeId])
  @@index([knowledgeSignalId])
}

// =============================================================================
// POST-EMAIL PIPELINE: Agentic Actions Audit + Document RAG
// =============================================================================

// Audit log for AI-proposed and executed actions in the deal pipeline
model crm_Agentic_Actions {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  campaign_id    String?   @db.ObjectId
  opportunity_id String?   @db.ObjectId
  contact_id     String?   @db.ObjectId
  account_id     String?   @db.ObjectId
  outreach_item_id String? @db.ObjectId

  action_type    String    // SEND_QUOTE, ATTACH_DOC, GENERATE_CONTRACT,
                           // CREATE_INVOICE, APPROVE_ENTITLEMENT, SEND_FOLLOWUP,
                           // MOVE_STAGE, ESCALATE_HUMAN, DRAFT_RESPONSE
  status         String    @default("PROPOSED") // PROPOSED, APPROVED, EXECUTED, REJECTED
  payload        Json      // Action parameters
  result         Json?     // Execution outcome
  reasoning      String?   // AI's explanation for proposing this action

  requires_human Boolean   @default(false)
  approved_by    String?   @db.ObjectId
  approved_at    DateTime? @db.Date
  executed_at    DateTime? @db.Date
  rejected_at    DateTime? @db.Date

  createdAt      DateTime  @default(now()) @db.Date
  team_id        String?   @db.ObjectId

  @@index([campaign_id])
  @@index([opportunity_id])
  @@index([team_id])
  @@index([status])
}

// Chunked document storage for RAG (semantic search over campaign collateral)
model crm_Document_Chunks {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  document_id String   @db.ObjectId
  chunk_index Int
  content     String   // Extracted text chunk (~500 tokens)
  embedding   Float[]  // Vector embedding for semantic search
  metadata    Json?    // Page number, section header, source range
  createdAt   DateTime @default(now()) @db.Date
  team_id     String?  @db.ObjectId

  @@index([document_id])
  @@index([team_id])
}

// -----------------------------------------------------------------------------
// APIM (API Management) Models - Phase 1
// -----------------------------------------------------------------------------

model crm_ApiKeys {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  tenant_id  String    @db.ObjectId
  name       String // e.g., "Next.js Production Key"
  key_prefix String // e.g., "sk_live_abc" (stored plain text for UI identification)
  key_hash   String // bcrypt hashed full key for secure validation
  status     String    @default("ACTIVE") // ACTIVE, REVOKED
  last_used  DateTime?
  created_by String    @db.ObjectId
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  team Team  @relation(fields: [tenant_id], references: [id])
  user Users @relation(fields: [created_by], references: [id])
}

// API Audit Logs for both Platform and Client usage visibility
model crm_ApiLogs {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenant_id   String   @db.ObjectId
  api_key_id  String?  @db.ObjectId // Optional if anonymous or failed
  endpoint    String
  method      String
  status_code Int
  ip_address  String?
  user_agent  String?
  request_dur Int? // Request duration in ms
  timestamp   DateTime @default(now())

  // We intentionally omit relation constraint to ApiKeys to preserve audit logs even if keys are deleted
}

// =============================================================================
// SANDBOX ENVIRONMENTS
// Isolated environments for testing configuration changes
// =============================================================================

enum SandboxStatus {
  ACTIVE
  PROMOTED
  DISCARDED
}

model Sandbox {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  name        String        // e.g., "Q3 Workflow Refactor"
  description String?
  status      SandboxStatus @default(ACTIVE)

  // Team scoping
  team_id   String @db.ObjectId
  team      Team   @relation(fields: [team_id], references: [id])

  // Audit
  created_by String   @db.ObjectId
  createdAt  DateTime @default(now()) @db.Date
  updatedAt  DateTime @updatedAt @db.Date

  // Track what was cloned into this sandbox
  cloned_entity_ids Json? // { workflows: [...], validationRules: [...], customObjects: [...], layouts: [...] }

  // Promotion tracking
  promotedAt DateTime? @db.Date
  promotedBy String?   @db.ObjectId

  // Relations
  deploy_logs SandboxDeployLog[]

  @@index([team_id])
  @@index([status])
}

model SandboxDeployLog {
  id         String @id @default(auto()) @map("_id") @db.ObjectId

  sandbox_id  String  @db.ObjectId
  sandbox     Sandbox @relation(fields: [sandbox_id], references: [id], onDelete: Cascade)

  // What happened
  action      String // CLONE, MODIFY, PROMOTE, DISCARD
  entity_type String // "crm_Workflow", "ValidationRule", "CustomObjectDefinition", "PageLayout"
  entity_id   String @db.ObjectId
  entity_name String? // Human-readable name of the entity

  // Change diff (for MODIFY and PROMOTE)
  diff Json? // { before: {...}, after: {...} }

  // Audit
  performed_by String   @db.ObjectId
  performedAt  DateTime @default(now()) @db.Date

  @@index([sandbox_id])
  @@index([entity_type])
}

// ═══════════════════════════════════════════════════════════════════
// CRON JOB REGISTRY — Per-team/user managed scheduled tasks
// ═══════════════════════════════════════════════════════════════════

enum CronJobStatus {
  ACTIVE     // Running on schedule
  PAUSED     // Temporarily disabled
  COMPLETED  // Finished (e.g., campaign ended)
  FAILED     // Too many consecutive errors
}

model crm_Cron_Jobs {
  id             String        @id @default(auto()) @map("_id") @db.ObjectId
  team_id        String        @db.ObjectId
  user_id        String        @db.ObjectId  // Creator/owner
  campaign_id    String?       @db.ObjectId  // Linked campaign (for follow-up jobs)

  job_type       String        // AUTO_FOLLOWUP, EMAIL_SYNC, DEAL_AGENT_CHECK, CUSTOM
  label          String?       // Human-readable name, e.g. "Follow-up: Enterprise Q3 Campaign"
  status         CronJobStatus @default(ACTIVE)

  // Schedule
  interval_ms    Int           @default(3600000) // Default 1 hour
  cron_expression String?      // Optional cron string for display ("0 */1 * * *")

  // Execution tracking
  last_run_at    DateTime?     @db.Date
  next_run_at    DateTime?     @db.Date
  run_count      Int           @default(0)
  error_count    Int           @default(0)
  last_error     String?
  last_result    Json?         // Summary of last execution

  // Limits (for future per-team quotas)
  max_runs       Int?          // Optional: stop after N runs
  expires_at     DateTime?     @db.Date // Optional: auto-pause after date

  createdAt      DateTime      @default(now()) @db.Date
  updatedAt      DateTime      @updatedAt     @db.Date

  @@index([team_id])
  @@index([status])
  @@index([job_type])
  @@index([campaign_id])
  @@index([next_run_at])
}

// ═══════════════════════════════════════════════════════════════════
// INBOX & EMAIL THREADING — Full email synchronization
// ═══════════════════════════════════════════════════════════════════

model crm_Email_Thread {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  team_id       String   @db.ObjectId
  user          String?  @db.ObjectId  // CRM user who sent the original
  lead          String?  @db.ObjectId  // Lead this thread is about
  campaign      String?  @db.ObjectId  // Campaign this belongs to
  outreach_item String?  @db.ObjectId

  // Thread metadata
  thread_subject String?
  message_id     String?  // Original outbound Message-ID or inbound Message-ID
  direction      String   // "OUTBOUND" or "INBOUND"

  // Email content
  from_email  String
  from_name   String?
  to_email    String
  subject     String?
  body_text   String?
  body_html   String?

  // Reply analysis
  sentiment     String?  // POSITIVE, NEGATIVE, NEUTRAL
  is_auto_reply Boolean  @default(false)

  createdAt     DateTime  @default(now()) @db.Date
  receivedAt    DateTime? @db.Date

  @@index([team_id])
  @@index([lead])
  @@index([message_id])
  @@index([outreach_item])
}
