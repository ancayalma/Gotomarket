// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// Team hierarchy types
enum TeamType {
  ORGANIZATION // Top-level team (e.g., "Acme Corp")
  DEPARTMENT // Sub-team/department (e.g., "Sales", "Marketing")
}

// ═══════════════════════════════════════════════════════════════════
// QUESTS — Team-scoped gamification challenges
// ═══════════════════════════════════════════════════════════════════

enum QuestStatus {
  DRAFT // Created but not yet visible to team
  ACTIVE // Live and trackable
  COMPLETED // Deadline passed or manually closed
  ARCHIVED // Retired / hidden
}

enum QuestDifficulty {
  EASY
  MEDIUM
  HARD
  LEGENDARY
}

model crm_Accounts {
  id                   String                @id @default(auto()) @map("_id") @db.ObjectId
  v                    Int                   @map("__v")
  createdAt            DateTime              @default(now()) @db.Date
  createdBy            String?               @db.ObjectId
  updatedAt            DateTime?             @updatedAt @db.Date
  updatedBy            String?               @db.ObjectId
  annual_revenue       String?
  assigned_to          String?               @db.ObjectId
  billing_city         String?
  billing_country      String?
  billing_postal_code  String?
  billing_state        String?
  billing_street       String?
  company_id           String?
  description          String?
  email                String?
  employees            String?
  fax                  String?
  industry             String?               @db.ObjectId
  member_of            String?
  name                 String
  office_phone         String?
  shipping_city        String?
  shipping_country     String?
  shipping_postal_code String?
  shipping_state       String?
  shipping_street      String?
  status               String?               @default("Inactive")
  type                 String?               @default("Customer")
  vat                  String?
  website              String?
  invoices             Invoices[]
  documentsIDs         String[]              @db.ObjectId
  assigned_documents   Documents[]           @relation(fields: [documentsIDs], references: [id])
  contacts             crm_Contacts[]
  leads                crm_Leads[]
  industry_type        crm_Industry_Type?    @relation(fields: [industry], references: [id])
  opportunities        crm_Opportunities[]
  assigned_to_user     Users?                @relation(fields: [assigned_to], references: [id], onDelete: SetNull)
  crm_accounts_tasks   crm_Accounts_Tasks[]
  contracts            crm_Contracts[]
  quotes               crm_Quotes[]
  watchers             String[]              @db.ObjectId
  watching_users       Users[]               @relation(name: "watching_accounts", fields: [watchers], references: [id])
  lead_candidates      crm_Lead_Candidates[] @relation(name: "LeadCandidatesAssignedAccounts")

  team_id       String? @db.ObjectId
  assigned_team Team?   @relation(fields: [team_id], references: [id])

  // Department assignment for scoped access
  assigned_department_id String? @db.ObjectId

  // Service Cloud: Cases linked to this account
  cases                 crm_Cases[]
  account_subscriptions crm_Subscriptions[]
  additional_emails     String[]

  // Account Hierarchy (parent/child companies)
  parent_account_id String?        @db.ObjectId
  parent_account    crm_Accounts?  @relation(name: "AccountHierarchy", fields: [parent_account_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  child_accounts    crm_Accounts[] @relation(name: "AccountHierarchy")

  // Synthesis Layer (AI Memory)
  contextNodes     ContextNode[]
  knowledgeSignals KnowledgeSignal[]

  // Service Cloud
  entitlements crm_Entitlement[]
}

model crm_Leads {
  id String @id @default(auto()) @map("_id") @db.ObjectId
  v  Int    @default(0) @map("__v")

  createdAt          DateTime?     @default(now()) @db.Date
  createdBy          String?       @db.ObjectId
  updatedAt          DateTime?     @updatedAt @db.Date
  updatedBy          String?       @db.ObjectId
  firstName          String?
  lastName           String
  company            String?
  jobTitle           String?
  email              String?
  phone              String?
  description        String?
  lead_source        String?
  refered_by         String?
  campaign           String?
  status             String?       @default("NEW")
  type               String?       @default("DEMO")
  assigned_to        String?       @db.ObjectId
  assigned_to_user   Users?        @relation(fields: [assigned_to], references: [id], onDelete: SetNull)
  accountsIDs        String?       @db.ObjectId
  assigned_accounts  crm_Accounts? @relation(fields: [accountsIDs], references: [id])
  documentsIDs       String[]      @db.ObjectId
  assigned_documents Documents[]   @relation(fields: [documentsIDs], references: [id])

  // Outreach tracking fields
  outreach_status            OutreachStatus? @default(IDLE)
  outreach_sent_at           DateTime?       @db.Date
  outreach_opened_at         DateTime?       @db.Date
  outreach_followup_sent_at  DateTime?       @db.Date
  outreach_meeting_link      String?
  outreach_meeting_booked_at DateTime?       @db.Date
  outreach_first_message_id  String?
  outreach_open_token        String?
  outreach_notes             String?
  pipeline_stage             PipelineStage?  @default(Identify)

  // Extended outreach channel fields
  outreach_transport  String?
  sms_status          String?
  sms_sent_at         DateTime? @db.Date
  last_sms_id         String?
  phone_verified      Boolean?  @default(false)
  call_status         String?
  connect_contact_id  String?
  call_recording_url  String?
  call_transcript_url String?
  aws_eum_session_id  String?
  opt_out             Boolean?  @default(false)
  voice_prompt_override String?

  lead_pool_maps         crm_Lead_Pools_Leads[]
  contact_candidate_maps crm_Contact_Candidate_Leads[]
  lead_activities        crm_Lead_Activities[]         @relation(name: "LeadActivitiesToLead")
  outreach_items         crm_Outreach_Items[]          @relation(name: "OutreachItemsLead")

  // Social profiles
  social_twitter  String?
  social_facebook String?
  social_linkedin String?

  // Link to a Project/Board for tagging and association
  project          String? @db.ObjectId
  assigned_project Boards? @relation(name: "LeadsAssignedProject", fields: [project], references: [id])

  // Message Portal recipients linked to this lead
  portal_recipients crm_Portal_Recipient[] @relation(name: "PortalRecipientLead")

  team_id       String? @db.ObjectId
  assigned_team Team?   @relation(fields: [team_id], references: [id])

  // Department assignment for scoped access
  assigned_department_id String?             @db.ObjectId
  additional_emails      String[]
  quotes                 crm_Quotes[]
  opportunities          crm_Opportunities[] @relation(name: "OpportunityToLeadRelation")

  // Synthesis Layer (AI Memory)
  contextNodes     ContextNode[]
  knowledgeSignals KnowledgeSignal[]
}

enum crm_Lead_Status {
  NEW
  CONTACTED
  QUALIFIED
  LOST
  CONVERTED
}

enum MfaMethod {
  NONE
  TOTP
  WEBAUTHN
  SMS
  EMAIL
}

enum crm_Lead_Type {
  DEMO
}

model crm_Opportunities {
  id                   String                          @id @default(auto()) @map("_id") @db.ObjectId
  v                    Int                             @default(0) @map("__v")
  account              String?                         @db.ObjectId
  assigned_to          String?                         @db.ObjectId
  budget               Int                             @default(0)
  campaign             String?                         @db.ObjectId
  close_date           DateTime?                       @db.Date
  contact              String?                         @db.ObjectId
  created_by           String?                         @db.ObjectId
  createdBy            String?                         @db.ObjectId
  created_on           DateTime?                       @default(now()) @db.Date
  createdAt            DateTime                        @default(now()) @db.Date
  last_activity        DateTime?                       @db.Date
  updatedAt            DateTime?                       @updatedAt @db.Date
  updatedBy            String?                         @db.ObjectId
  last_activity_by     String?                         @db.ObjectId
  currency             String?
  description          String?
  expected_revenue     Int                             @default(0)
  name                 String?
  next_step            String?
  sales_stage          String?                         @db.ObjectId
  type                 String?                         @db.ObjectId
  status               crm_Opportunity_Status?         @default(ACTIVE)
  assigned_type        crm_Opportunities_Type?         @relation(fields: [type], references: [id])
  assigned_sales_stage crm_Opportunities_Sales_Stages? @relation(name: "assinged_sales_stage", fields: [sales_stage], references: [id])
  assigned_to_user     Users?                          @relation(name: "assigned_to_user_relation", fields: [assigned_to], references: [id], onDelete: SetNull)
  created_by_user      Users?                          @relation(name: "created_by_user_relation", fields: [created_by], references: [id], onDelete: SetNull)
  assigned_account     crm_Accounts?                   @relation(fields: [account], references: [id])
  assigned_lead        crm_Leads?                      @relation(name: "OpportunityToLeadRelation", fields: [lead_id], references: [id])
  assigned_campaings   crm_campaigns?                  @relation(fields: [campaign], references: [id])
  connected_documents  String[]                        @db.ObjectId
  documents            Documents[]                     @relation(fields: [connected_documents], references: [id])
  invoiceIDs           String[]                        @db.ObjectId
  invoices             Invoices[]                      @relation(fields: [invoiceIDs], references: [id])
  connected_contacts   String[]                        @db.ObjectId
  contacts             crm_Contacts[]                  @relation(fields: [connected_contacts], references: [id])
  quotes               crm_Quotes[]

  team_id       String? @db.ObjectId
  assigned_team Team?   @relation(fields: [team_id], references: [id])

  // Department assignment for scoped access
  assigned_department_id String? @db.ObjectId

  // Project Linkage
  project          String? @db.ObjectId
  assigned_project Boards? @relation(fields: [project], references: [id])

  lead_source String?
  lead_id     String? @db.ObjectId

  // Multi-Currency Support
  currency_code      String? @default("USD") // ISO 4217 code
  converted_budget   Float?  // Budget converted to team's base currency
  converted_revenue  Float?  // Revenue converted to team's base currency

  // Competitor Tracking
  competitors crm_Opportunity_Competitors[]

  // Revenue Splits (multi-rep credit)
  splits crm_Opportunity_Splits[]
}

enum crm_Opportunity_Status {
  ACTIVE
  INACTIVE
  PENDING
  CLOSED
}

// ── Competitor Tracking ─────────────────────────────────────────────────────
enum CompetitorThreatLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum CompetitorOutcome {
  ACTIVE       // Still competing
  WON_AGAINST  // We won the deal
  LOST_TO      // We lost to this competitor
  NO_DECISION  // Deal was lost to no decision
}

model crm_Opportunity_Competitors {
  id             String               @id @default(auto()) @map("_id") @db.ObjectId
  opportunity_id String               @db.ObjectId
  opportunity    crm_Opportunities    @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  name           String               // Competitor company name
  website        String?              // Competitor website
  contact_name   String?              // Their sales rep if known
  product        String?              // Competing product/solution
  strengths      String?              // Their key strengths
  weaknesses     String?              // Their known weaknesses
  strategy       String?              // Our counter-strategy
  threat_level   CompetitorThreatLevel @default(MEDIUM)
  outcome        CompetitorOutcome     @default(ACTIVE)
  price_position String?              // e.g., "20% lower", "premium"

  createdAt      DateTime             @default(now()) @db.Date
  updatedAt      DateTime?            @updatedAt @db.Date
  createdBy      String?              @db.ObjectId

  @@index([opportunity_id])
}

// ── Revenue Splits (Multi-Rep Credit) ───────────────────────────────────────
enum SplitType {
  PRIMARY   // Primary deal owner
  OVERLAY   // Overlay specialist (e.g., SE, solutions)
  SUPPORT   // Supporting role
  REFERRAL  // Referral credit
}

model crm_Opportunity_Splits {
  id             String            @id @default(auto()) @map("_id") @db.ObjectId
  opportunity_id String            @db.ObjectId
  opportunity    crm_Opportunities @relation(fields: [opportunity_id], references: [id], onDelete: Cascade)

  user_id        String            @db.ObjectId
  user           Users             @relation(name: "OpportunitySplitUser", fields: [user_id], references: [id], onDelete: Cascade)

  split_pct      Float             // Percentage (0-100), all splits on an opp should sum to 100
  split_type     SplitType         @default(PRIMARY)
  revenue_credit Float?            // Calculated: expected_revenue * (split_pct / 100)
  note           String?           // Optional note for this split

  createdAt      DateTime          @default(now()) @db.Date
  updatedAt      DateTime?         @updatedAt @db.Date

  @@unique([opportunity_id, user_id])
  @@index([user_id])
}

// ── Multi-Currency Exchange Rates ───────────────────────────────────────────
model crm_Currency {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  code                String   @unique // ISO 4217: USD, EUR, GBP, JPY, etc.
  name                String   // "US Dollar", "Euro", etc.
  symbol              String   // "$", "€", "£", "¥"
  decimal_places      Int      @default(2)
  exchange_rate_to_usd Float   // 1 unit of this currency = X USD
  is_active           Boolean  @default(true)

  // Team scope (null = system-wide default rates)
  team_id             String?  @db.ObjectId

  last_updated        DateTime @default(now()) @db.Date
  createdAt           DateTime @default(now()) @db.Date

  @@unique([code, team_id])
  @@index([team_id])
}

model crm_campaigns {
  id            String              @id @default(auto()) @map("_id") @db.ObjectId
  v             Int                 @map("__v")
  name          String
  description   String?
  status        String?
  opportunities crm_Opportunities[]
}

// Outreach Campaigns for Email/SMS tracking
enum OutreachCampaignStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  PAUSED
  COMPLETED
  ARCHIVED
}

enum OutreachChannelType {
  EMAIL
  SMS
  PHONE
  LINKEDIN
}

model crm_Outreach_Campaigns {
  id          String                 @id @default(auto()) @map("_id") @db.ObjectId
  v           Int?                   @map("__v")
  name        String
  description String?
  status      OutreachCampaignStatus @default(DRAFT)

  // Owner/Team
  user    String? @db.ObjectId
  team_id String? @db.ObjectId

  // Members assigned to work on this campaign (for collaboration)
  assigned_users String[] @db.ObjectId

  // Project/Context association
  project String? @db.ObjectId
  pool    String? @db.ObjectId

  // Campaign-specific overrides
  prompt_override   String?
  signature_html    String?
  signature_meta    Json?
  resource_links    Json?
  meeting_link      String?
  campaign_branding Json? // Snapshot/Override of TeamBrandIdentity for this specific campaign

  // Follow-up automation config
  followup_enabled       Boolean  @default(true)
  followup_delay_hours   Int      @default(72)  // User-configurable wait before auto-followup
  followup_max_count     Int      @default(2)   // Max follow-ups per contact
  followup_prompt        String?                // Custom follow-up prompt override

  // Auto-reply AI config
  auto_reply_enabled     Boolean  @default(false)
  auto_reply_max_count   Int      @default(3)   // Max auto-replies per lead thread
  auto_reply_prompt      String?                // Custom reply prompt override

  // Campaign collateral (pricing sheets, agreements, etc.)
  document_ids           String[] @db.ObjectId

  // Voice AI Scheduling Config
  voice_agent_id          String?
  voice_start_time        DateTime? @db.Date
  voice_concurrency_limit Int       @default(1)
  voice_prompt            String?

  // Channels enabled
  channels OutreachChannelType[] @default([EMAIL])

  // Stats (denormalized for quick access)
  total_leads     Int @default(0)
  emails_sent     Int @default(0)
  emails_opened   Int @default(0)
  emails_replied  Int @default(0)
  sms_sent        Int @default(0)
  sms_delivered   Int @default(0)
  calls_initiated Int @default(0)
  meetings_booked Int @default(0)

  // A/B Testing
  ab_enabled               Boolean  @default(false)
  ab_winner_metric         String?  // "open_rate", "reply_rate", "click_rate"
  ab_winner_variant        String?  // Winning variant ID
  ab_auto_winner_threshold Int?     @default(100) // Min sends before auto-picking winner
  ab_decided_at            DateTime? @db.Date

  // Repair Sequence Tracking
  repair_active            Boolean?  @default(false)
  repair_progress          Json?     // { current: 0, total: 100 }
  repair_stream            String?   // Real-time reasoning stream

  // Timestamps
  createdAt   DateTime? @default(now()) @db.Date
  updatedAt   DateTime? @updatedAt @db.Date
  launchedAt  DateTime? @db.Date
  completedAt DateTime? @db.Date

  // Relations
  outreach_items crm_Outreach_Items[]
  ab_variants    crm_Outreach_AB_Variant[]
  assigned_user    Users?               @relation(name: "OutreachCampaignsUser", fields: [user], references: [id], onDelete: SetNull)
  assigned_team    Team?                @relation(name: "OutreachCampaignsTeam", fields: [team_id], references: [id])
  assigned_project Boards?              @relation(name: "OutreachCampaignsProject", fields: [project], references: [id])
  assigned_pool    crm_Lead_Pools?      @relation(name: "OutreachCampaignsPools", fields: [pool], references: [id])
}

// Individual outreach items within a campaign
enum OutreachItemStatus {
  PENDING
  RESEARCHING
  READY
  SENT
  DELIVERED
  OPENED
  CLICKED
  REPLIED
  BOUNCED
  FAILED
  SKIPPED
}

model crm_Outreach_Items {
  id       String              @id @default(auto()) @map("_id") @db.ObjectId
  v        Int?                @map("__v")
  campaign String              @db.ObjectId
  lead     String?             @db.ObjectId
  channel  OutreachChannelType
  status   OutreachItemStatus  @default(PENDING)

  // Research data collected for personalization
  research_data Json?

  // Generated content
  subject   String?
  body_text String?
  body_html String?

  // A/B Testing: which variant was used for this item
  ab_variant_id String? @db.ObjectId

  // LinkedIn-specific fields
  linkedin_profile_url String?
  linkedin_message     String?
  linkedin_action      String? // "connect", "message", "inmail"

  // Tracking
  message_id       String?
  tracking_token   String?
  unsubscribe_token String?

  // Timestamps
  createdAt   DateTime? @default(now()) @db.Date
  sentAt      DateTime? @db.Date
  deliveredAt DateTime? @db.Date
  openedAt    DateTime? @db.Date
  clickedAt   DateTime? @db.Date
  repliedAt   DateTime? @db.Date

  // Reply tracking & sentiment
  reply_snippet     String?
  reply_sentiment   String?   // POSITIVE, NEGATIVE, NEUTRAL
  reply_analyzed_at DateTime? @db.Date

  // Follow-up tracking
  followup_count    Int       @default(0)
  auto_reply_count  Int       @default(0)
  next_followup_at  DateTime? @db.Date
  unsubscribed_at   DateTime? @db.Date

  // Candidate data (for pool contacts not yet in crm_Leads)
  candidate_email     String?
  candidate_name      String?
  candidate_company   String?
  candidate_job_title String?

  // Cross-module links
  account_id String? @db.ObjectId
  contact_id String? @db.ObjectId

  // Error tracking
  error_message String?
  retry_count   Int     @default(0)

  // Sender tracking (which email address was used to send this item)
  sender_email  String?

  // Relations
  assigned_campaign crm_Outreach_Campaigns? @relation(fields: [campaign], references: [id])
  assigned_lead     crm_Leads?              @relation(name: "OutreachItemsLead", fields: [lead], references: [id])

  // Synthesis Layer (AI Memory)
  knowledgeSignals KnowledgeSignal[]

  // A/B variant relation
  variant crm_Outreach_AB_Variant? @relation(fields: [ab_variant_id], references: [id])
}

// A/B Test Variants for Outreach Templates
model crm_Outreach_AB_Variant {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  campaign_id String @db.ObjectId
  name        String // e.g., "Variant A", "Variant B"
  weight      Int    @default(50) // % of traffic
  is_control  Boolean @default(false)

  // Template content
  subject       String?
  body_template String?
  body_html     String?
  tone          String? // "formal", "casual", "direct", "empathetic"
  cta_text      String?
  cta_url       String?

  // Performance metrics (denormalized)
  total_sent     Int @default(0)
  total_opened   Int @default(0)
  total_clicked  Int @default(0)
  total_replied  Int @default(0)
  total_bounced  Int @default(0)

  open_rate  Float @default(0)
  click_rate Float @default(0)
  reply_rate Float @default(0)

  is_winner Boolean @default(false)

  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  // Relations
  campaign crm_Outreach_Campaigns @relation(fields: [campaign_id], references: [id])
  items    crm_Outreach_Items[]

  @@index([campaign_id])
}

model crm_Outreach_Drafts {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  user_id   String   @db.ObjectId
  pool_id   String   @db.ObjectId
  name      String   @default("Untitled Draft")
  state     Json     // full wizard state snapshot
  createdAt DateTime @default(now()) @db.Date
  updatedAt DateTime @updatedAt @db.Date

  owner Users          @relation(name: "OutreachDraftsOwner", fields: [user_id], references: [id], onDelete: Cascade)
  pool  crm_Lead_Pools @relation(name: "OutreachDraftsPool", fields: [pool_id], references: [id], onDelete: Cascade)

  @@unique([user_id, pool_id])
  @@index([user_id])
  @@index([pool_id])
}

model crm_Opportunities_Sales_Stages {
  id                                 String              @id @default(auto()) @map("_id") @db.ObjectId
  v                                  Int                 @map("__v")
  name                               String
  probability                        Int?
  order                              Int?
  assigned_opportunities_sales_stage crm_Opportunities[] @relation(name: "assinged_sales_stage")
}

model crm_Opportunities_Type {
  id                     String              @id @default(auto()) @map("_id") @db.ObjectId
  v                      Int                 @map("__v")
  name                   String
  order                  Int?
  assigned_opportunities crm_Opportunities[]
}

model crm_Contacts {
  id                     String              @id @default(auto()) @map("_id") @db.ObjectId
  v                      Int                 @default(0) @map("__v")
  account                String?             @db.ObjectId
  assigned_to            String?             @db.ObjectId
  birthday               String?
  created_by             String?             @db.ObjectId
  createdBy              String?             @db.ObjectId
  created_on             DateTime?           @default(now())
  cratedAt               DateTime?           @default(now()) @db.Date
  last_activity          DateTime?           @default(now()) @db.Date
  updatedAt              DateTime?           @updatedAt @db.Date
  updatedBy              String?             @db.ObjectId
  last_activity_by       String?             @db.ObjectId
  description            String?
  email                  String?
  email_unsubscribed     Boolean?            @default(false)
  personal_email         String?
  first_name             String?
  last_name              String
  office_phone           String?
  mobile_phone           String?
  opt_out                Boolean?            @default(false)
  website                String?
  position               String?
  status                 Boolean             @default(true)
  social_twitter         String?
  social_facebook        String?
  social_linkedin        String?
  social_skype           String?
  social_instagram       String?
  social_youtube         String?
  social_tiktok          String?
  type                   String?             @default("Customer")
  tags                   String[]
  notes                  String[]
  assigned_to_user       Users?              @relation(name: "assigned_contacts", fields: [assigned_to], references: [id], onDelete: SetNull)
  crate_by_user          Users?              @relation(name: "created_contacts", fields: [created_by], references: [id], onDelete: SetNull)
  opportunitiesIDs       String[]            @db.ObjectId
  assigned_opportunities crm_Opportunities[] @relation(fields: [opportunitiesIDs], references: [id])
  accountsIDs            String?             @db.ObjectId
  assigned_accounts      crm_Accounts?       @relation(fields: [accountsIDs], references: [id])
  documentsIDs           String[]            @db.ObjectId
  assigned_documents     Documents[]         @relation(fields: [documentsIDs], references: [id])

  team_id       String? @db.ObjectId
  assigned_team Team?   @relation(fields: [team_id], references: [id])

  // Department assignment for scoped access
  assigned_department_id String? @db.ObjectId

  // Service Cloud: Cases linked to this contact
  cases  crm_Cases[]
  quotes crm_Quotes[]

  // API messaging: Activities linked to this contact
  lead_activities crm_Lead_Activities[] @relation(name: "LeadActivitiesToContact")

  // Portal access tokens
